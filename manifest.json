{
  "id": "com.harborclient.plugins.mock-server",
  "name": "Mock Server",
  "version": "1.0.2",
  "author": "HarborClient",
  "summary": "Run a local WireMock-style HTTP mock server with method/path stubs, custom status codes, headers, bodies, and delays.",
  "description": "README.md",
  "categories": ["mock", "requests", "scripting"],
  "screenshots": [
    "https://raw.githubusercontent.com/harborclient/plugin-mock-server/main/screenshot.png"
  ],
  "engines": {
    "harborclient": ">=2.5.4"
  },
  "renderer": "dist/renderer.js",
  "main": "dist/main.js",
  "permissions": ["ui", "ipc", "server", "storage"],
  "contributes": {
    "footerPanels": [
      {
        "id": "mock-server.panel",
        "title": "Mock server"
      }
    ],
    "mainViews": [
      {
        "id": "mock-server.view",
        "title": "Mock Server",
        "icon": "server"
      }
    ]
  }
}
